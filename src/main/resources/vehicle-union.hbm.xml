<hibernate-mapping>

    <!-- The root/parent class must be abstract for union-subclass mapping -->
    <!-- It does not get its own dedicated physical database table -->
    <class name="org.example.modal.inheritance.Vehicle" abstract="true">

        <id name="id">
            <generator class="sequence"/>
        </id>

        <!--<id name="id" type="long" column="vehicle_id">
            <generator class="sequence">
                <param name="sequence_name">vehicle_seq</param>
            </generator>
        </id>-->

        <!-- Common properties inherited by all subclasses -->
        <property name="name"/>

        <!-- Subclass 1: Car mapped to its own independent table -->
        <union-subclass name="org.example.modal.inheritance.Car" table="car">
            <!-- Specific properties only for Car -->
            <property name="seatingCapacity"/>
        </union-subclass>

        <!-- Subclass 2: Bike mapped to its own independent table -->
        <union-subclass name="org.example.modal.inheritance.Bike" table="bike">
            <!-- Specific properties only for Bike -->
            <property name="engineCapacity"/>
        </union-subclass>

    </class>

</hibernate-mapping>
