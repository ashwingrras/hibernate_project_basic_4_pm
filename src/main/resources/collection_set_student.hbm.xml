

<hibernate-mapping>
    <class name="org.example.modal.collection.Student" table="student">
        <id name="id">
            <generator class="native"/>
        </id>

        <property name ="name"/>

        <!--<set name="courses" table="student_courses">
            <key column="student_id"/>
            <element column="course" type="string"/>
        </set>-->

        <!--<list name="courses" table="student_courses">
            <key column="student_id"/>
            <list-index column="course_order"/>
            <element column="course" type="string"/>
        </list>-->

        <bag name="courses" table="student_courses">
            <key column="student_id"/>
            <element column="course" type="string"/>
        </bag>

        <map name="addresses" table="student_address">
            <key column="student_id"/>
            <map-key column="address_type" type="string"/>
            <element column="address" type="string"/>
        </map>

    </class>
</hibernate-mapping>